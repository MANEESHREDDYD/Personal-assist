{
  "name": "personal-assist",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "dev:safe": "node scripts/start-personal-assist-dev.mjs",
    "dev:stop": "node scripts/stop-personal-assist-dev.mjs",
    "db:push": "npx prisma db push",
    "db:seed": "node scripts/seed.js",
    "db:reset": "node scripts/reset-db.js && npx prisma db push && npm run db:seed",
    "worker": "tsx scripts/local-worker.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run worker\"",
    "smoke:test": "tsx scripts/smoke-test.ts",
    "analytics:run": "python analytics/personal_assist_analytics/run.py",
    "analytics:report": "python analytics/personal_assist_analytics/report.py",
    "repo:languages": "node scripts/language-breakdown.mjs",
    "verify:live-provider-env": "node scripts/live-provider-preflight.mjs",
    "security:no-send": "node scripts/check-no-send-policy.mjs",
    "security:demo-evidence": "node scripts/check-demo-evidence-hygiene.mjs",
    "demo:provider-draft-fixture": "tsx scripts/create-demo-provider-draft-fixture.ts",
    "test:provider-attachments": "tsx scripts/test-provider-attachments.ts",
    "test:scheduling": "tsx scripts/test-scheduling.ts",
    "test:booking": "tsx scripts/test-booking.ts",
    "test:scheduling-secretary": "tsx scripts/test-scheduling-secretary.ts",
    "test:planner": "tsx scripts/test-planner.ts",
    "test:projects": "tsx scripts/test-projects.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@prisma/client": "^5.22.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.17.0",
    "mailparser": "^3.9.9",
    "mammoth": "^1.12.0",
    "next": "16.2.7",
    "node-ical": "^0.26.1",
    "pdf-parse": "^2.4.5",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.10.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^20",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^10.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "prisma": "^5.22.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
