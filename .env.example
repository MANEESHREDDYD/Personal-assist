# Personal Assist environment template.
# Copy this file to .env for local development. Never commit .env.
# Use test Gmail and Outlook/Microsoft accounts for live provider verification.
# Provider draft permissions are broader than read-only permissions.
# Personal Assist creates drafts only and never sends email.

# App
DATABASE_URL="file:./dev.db"
AI_PROVIDER=rules
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Encryption
# Use a 32-byte base64 value or a 32-character string.
ENCRYPTION_KEY=replace_with_32_byte_base64_or_32_char_key

# Gmail read-only
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/integrations/gmail/callback

# Google Calendar read-only
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:3000/api/integrations/google-calendar/callback

# Outlook read-only
# Uses the Microsoft app credentials in the Outlook Draft connector section below.
MICROSOFT_REDIRECT_URI=http://localhost:3000/api/integrations/outlook-calendar/callback
MICROSOFT_OUTLOOK_MAIL_REDIRECT_URI=http://localhost:3000/api/integrations/outlook-mail/callback

# Gmail Draft connector
# Required scope: https://www.googleapis.com/auth/gmail.compose
GOOGLE_GMAIL_DRAFT_CLIENT_ID=
GOOGLE_GMAIL_DRAFT_CLIENT_SECRET=
GOOGLE_GMAIL_DRAFT_REDIRECT_URI=http://localhost:3000/api/integrations/gmail-draft/callback

# Outlook Draft connector
# Required delegated permissions: User.Read, offline_access, Mail.ReadWrite
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common
MICROSOFT_OUTLOOK_DRAFT_REDIRECT_URI=http://localhost:3000/api/integrations/outlook-draft/callback
